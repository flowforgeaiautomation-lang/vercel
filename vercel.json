{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "buildCommand": "npm run build && rm -rf dist && npm run build",
  "installCommand": "npm install",
  "cleanUrls": true,
  "functions": {
    "cache": {
      "maxAge": 0
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
